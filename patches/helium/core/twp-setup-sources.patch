+# Copyright 2026 The Helium Authors
+# You can use, redistribute, and/or modify this source code under
+# the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+import("//ui/webui/resources/tools/generate_grd.gni")
+import("//tools/grit/grit_rule.gni")
+
+file_list = "$target_gen_dir/files.json"
+generated_grd = "$target_gen_dir/twp_resources.grd"
+
+action("generate_file_list") {
+    script = "generate_file_list.py"
+    args = [
+        rebase_path("."),
+        rebase_path(file_list),
+    ]
+    inputs = [
+        "manifest.json",
+        "generate_file_list.py",
+    ]
+    outputs = [ file_list ]
+}
+
+generate_grd("twp_grd") {
+    out_grd = generated_grd
+
+    grd_prefix = "twp"
+    resource_path_prefix = "twp"
+
+    manifest_files = [ file_list ]
+    deps = [":generate_file_list"]
+}
+
+grit("twp") {
+    source = generated_grd
+
+    # Required because the .grd is generated.
+    enable_input_discovery_for_gn_analyze = false
+    use_brotli = true
+
+    output_dir = "$target_gen_dir/resources"
+
+    outputs = [
+        "grit/twp_resources.h",
+        "grit/twp_resources_map.cc",
+        "grit/twp_resources_map.h",
+        "twp_resources.pak"
+    ]
+
+    deps = [":twp_grd"]
+}
